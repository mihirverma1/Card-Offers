{
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "api/offers.js", "use": "@vercel/node", "config": { "maxDuration": 30 } }
  ],
  "routes": [
    { "src": "/api/offers", "methods": ["GET", "POST", "OPTIONS"], "dest": "/api/offers.js" },
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" }
  ]
}
