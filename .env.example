# ---------------------------------------------------------------------------
# Environment variables for the Card Offers backend (set these in Vercel:
# Project -> Settings -> Environment Variables, then redeploy).
# ---------------------------------------------------------------------------

# Supabase (the offers database / cache)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-secret

# Search providers (find the offer pages)
TAVILY_API_KEY=tvly-your-tavily-key
FIRECRAWL_API_KEY=fc-your-firecrawl-key

# Extraction (turn pages into structured offers). Priority order:
#   1) Firecrawl AI extraction   -> uses FIRECRAWL_API_KEY (above)
#   2) OpenRouter free model     -> failsafe
#   3) Gemini                    -> optional, only if a key is set
# OpenRouter (https://openrouter.ai/keys) — a free key works with :free models
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional
GEMINI_API_KEY=your-google-gemini-key   # optional fallback
GEMINI_MODEL=gemini-2.0-flash
OFFERS_CACHE_DAYS=7                       # re-crawl a card's offers if older than this

# Comma-separated origins allowed to call the backend (website + "null" for the app)
ALLOWED_ORIGINS=https://your-project.vercel.app,null
