# Web-search providers for /api/offers (tried in this order: Firecrawl -> Tavily -> SerpAPI).
# Configure at least one; without any key the backend returns local estimates only.
FIRECRAWL_API_KEY=fc-your-firecrawl-key
TAVILY_API_KEY=tvly-your-tavily-key
SERPAPI_API_KEY=your-serpapi-key

# Comma-separated origins allowed to call the backend.
# For production, set this to your Vercel URL and app domain.
ALLOWED_ORIGINS=https://your-project.vercel.app
